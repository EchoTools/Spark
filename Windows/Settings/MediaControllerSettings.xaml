<UserControl x:Class="Spark.MediaControllerSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:l="clr-namespace:Spark"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="580"
             Background="{DynamicResource ControlDarkerBackground}"
             FontSize="14"
             DataContext="{Binding RelativeSource={RelativeSource Self}}"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,12,12,16">

            <!-- Header -->
            <Label Content="Media Controller" FontSize="16" Margin="0,0,0,2"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.65" FontSize="12" Margin="4,0,0,12"
                       Text="Control your music from inside EchoVR using the mute button. Requires EchoVR running on this PC."/>

            <!-- Status bar -->
            <Border Background="{DynamicResource ContainerBackground}"
                    CornerRadius="4" BorderBrush="{DynamicResource ControlDefaultBorderBrush}"
                    BorderThickness="1" Padding="10,8" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10"
                             Fill="#c0392b" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="EchoVR: Disconnected"
                               VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ActionText" Text="" Opacity="0.7" FontSize="12"
                               Margin="16,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Exclusivity warning -->
            <Border x:Name="MediaExclusivityWarning" Visibility="Collapsed"
                    Background="#33c0392b" CornerRadius="4"
                    BorderBrush="#c0392b" BorderThickness="1"
                    Padding="10,8" Margin="0,0,0,10">
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Text="⚠  Cannot enable — Controller Clipping is currently active. Disable it in the Clips → Controller tab first."/>
            </Border>

            <!-- Enable toggle -->
            <CheckBox x:Name="EnableCheckBox"
                      Content="Enable Media Controller"
                      IsChecked="{l:SettingBinding mediaControllerEnabled}"
                      Margin="4,0,0,12"
                      Checked="EnableChecked"
                      Unchecked="EnableUnchecked"/>

            <!-- Settings group -->
            <GroupBox Header="Settings" Margin="0,0,0,10"
                      Background="{DynamicResource ControlDarkerBackground}"
                      BorderBrush="{DynamicResource ControlDefaultBorderBrush}">
                <StackPanel Margin="8,6,8,8" Background="{DynamicResource ControlDarkerBackground}">

                    <!-- Hold threshold -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Label Content="Hold for Play/Pause:" Width="180"/>
                        <TextBox x:Name="HoldThresholdBox"
                                 Text="{l:SettingBinding mediaControllerHoldThreshold}"
                                 Width="60" Padding="4,2" VerticalContentAlignment="Center"
                                 Background="{DynamicResource ControlDefaultBackground}"
                                 TextChanged="NumericBox_TextChanged"/>
                        <Label Content="seconds" Margin="4,0,0,0" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Prev clicks -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Label Content="Clicks for Prev Track:" Width="180"/>
                        <TextBox x:Name="PrevClicksBox"
                                 Text="{l:SettingBinding mediaControllerPrevClicks}"
                                 Width="60" Padding="4,2" VerticalContentAlignment="Center"
                                 Background="{DynamicResource ControlDefaultBackground}"
                                 TextChanged="NumericBox_TextChanged"/>
                        <Label Content="clicks" Margin="4,0,0,0" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Next clicks -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Label Content="Clicks for Next Track:" Width="180"/>
                        <TextBox x:Name="NextClicksBox"
                                 Text="{l:SettingBinding mediaControllerNextClicks}"
                                 Width="60" Padding="4,2" VerticalContentAlignment="Center"
                                 Background="{DynamicResource ControlDefaultBackground}"
                                 TextChanged="NumericBox_TextChanged"/>
                        <Label Content="clicks" Margin="4,0,0,0" Opacity="0.7"/>
                    </StackPanel>

                    <!-- Click timeout -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Label Content="Multi-click window:" Width="180"/>
                        <TextBox x:Name="ClickTimeoutBox"
                                 Text="{l:SettingBinding mediaControllerClickTimeout}"
                                 Width="60" Padding="4,2" VerticalContentAlignment="Center"
                                 Background="{DynamicResource ControlDefaultBackground}"
                                 TextChanged="NumericBox_TextChanged"/>
                        <Label Content="seconds" Margin="4,0,0,0" Opacity="0.7"/>
                    </StackPanel>

                    <Separator Margin="0,8,0,8"/>

                    <!-- Auto-reconnect -->
                    <CheckBox Content="Auto-reconnect when EchoVR is not found"
                              IsChecked="{l:SettingBinding mediaControllerAutoReconnect}"
                              Margin="0,2,0,2"/>

                </StackPanel>
            </GroupBox>

            <!-- Controls reference -->
            <GroupBox Header="Mute Button Mappings" Margin="0,0,0,10"
                      Background="{DynamicResource ControlDarkerBackground}"
                      BorderBrush="{DynamicResource ControlDefaultBorderBrush}">
                <StackPanel Margin="8,6,8,8" Background="{DynamicResource ControlDarkerBackground}">
                    <TextBlock Opacity="0.75" FontSize="12">
                        <Run FontFamily="Consolas">Hold 3s</Run><Run>  →  Play / Pause</Run>
                        <LineBreak/>
                        <Run FontFamily="Consolas">3 clicks</Run><Run>  →  Previous Track (configurable above)</Run>
                        <LineBreak/>
                        <Run FontFamily="Consolas">4 clicks</Run><Run>  →  Next Track (configurable above)</Run>
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <!-- Test controls -->
            <GroupBox Header="Test Controls" Margin="0,0,0,10"
                      Background="{DynamicResource ControlDarkerBackground}"
                      BorderBrush="{DynamicResource ControlDefaultBorderBrush}">
                <StackPanel Orientation="Horizontal" Margin="8,8,8,8"
                            Background="{DynamicResource ControlDarkerBackground}">
                    <Button Content="⏮  Prev Track"  Width="120" Margin="0,0,8,0" Padding="6,4"
                            Click="PrevTrackClick"/>
                    <Button Content="⏯  Play / Pause" Width="130" Margin="0,0,8,0" Padding="6,4"
                            Click="PlayPauseClick"/>
                    <Button Content="⏭  Next Track"  Width="120" Padding="6,4"
                            Click="NextTrackClick"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
