<UserControl x:Class="Spark.FriendsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:l="clr-namespace:Spark"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">
    <Grid Background="#121212">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- LEFT: Friends List                          -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Friends" FontSize="24" FontWeight="Bold" 
                           Foreground="White" VerticalAlignment="Center"/>
                <Border x:Name="OnlineCountBadge" Background="#2D7D46" CornerRadius="10" Padding="8,2" 
                        Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="OnlineCountText" Text="0 Online" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#A18413" CornerRadius="10" Padding="8,2" 
                        Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="WIP" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <!-- Not logged in panel -->
            <Border x:Name="NotLoggedInPanel" Grid.Row="1" Background="#1E1E1E"
                    BorderBrush="#333333" BorderThickness="1" CornerRadius="8"
                    Padding="40" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Log in with Discord to use Friends" FontSize="18" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="12" 
                               Foreground="#888888" MaxWidth="320">
                        Use the Discord login button at the top left of Spark.
                        Once logged in, your friend code will appear on the right
                        and you can start adding friends.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Friends list (visible when logged in) -->
            <ScrollViewer x:Name="FriendsSection" Grid.Row="1" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                <StackPanel>
                    <ItemsControl x:Name="FriendsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" BorderBrush="#333333" 
                                        BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="16,12"
                                        Opacity="{Binding Opacity}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Width="12" Height="12" Fill="{Binding StatusColor}" VerticalAlignment="Top" Margin="0,4,16,0"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="Bold" 
                                                           Foreground="White"/>
                                                <Border Background="{Binding TeamColor}" CornerRadius="4" Padding="7,2" Margin="10,0,0,0" 
                                                        VerticalAlignment="Center" Visibility="{Binding ShowStatusBadge}">
                                                    <TextBlock Text="{Binding StatusBadgeText}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock FontSize="12" Foreground="#AAAAAA" Margin="0,4,0,0" TextWrapping="Wrap">
                                                <Run Text="{Binding ModeText}" FontWeight="SemiBold"/>
                                                <Run Text="{Binding SeparatorText}"/>
                                                <Run Text="{Binding SessionTypeText}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding SessionIdText}" FontSize="10" Foreground="#555555" Margin="0,2,0,0" Visibility="{Binding ShowStatusBadge}"/>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="×" Width="30" Height="30" Margin="0,0,10,0"
                                                Background="Transparent" BorderThickness="0" 
                                                Foreground="#444444" FontSize="18"
                                                VerticalAlignment="Center" Click="RemoveFriendClicked" Tag="{Binding FriendCode}"
                                                ToolTip="Remove friend"/>

                                        <Button Grid.Column="3" Content="Join" Width="70" Height="32"
                                                Background="{Binding TeamColor}" Foreground="White" 
                                                BorderThickness="0" FontWeight="Bold" VerticalAlignment="Center"
                                                IsEnabled="{Binding IsJoinable}" Visibility="{Binding ShowJoinButton}"
                                                Click="JoinFriendClicked">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <Border x:Name="EmptyFriendsHint" Background="Transparent" Padding="40" Visibility="Visible">
                        <TextBlock Text="No friends added yet. Enter a friend code on the right to get started!" 
                                   Foreground="#666666" TextWrapping="Wrap" FontSize="13" TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!-- RIGHT: Side Panel                           -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="#181818" 
                BorderBrush="#252525" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">

                    <!-- Add Friend -->
                    <TextBlock Text="Add Friend" FontSize="18" FontWeight="Bold" 
                               Foreground="White" Margin="0,0,0,6"/>
                    <TextBlock Text="Enter a friend code to add them to your list." 
                               FontSize="12" Foreground="#888888" 
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <TextBox x:Name="AddFriendCodeBox" Height="34" VerticalContentAlignment="Center" Padding="10,0"
                             Background="#121212" Foreground="White" BorderBrush="#333333"
                             MaxLength="9" FontSize="14" KeyDown="AddFriendKeyDown"/>

                    <Button Content="Add Friend" Height="34" Margin="0,10,0,0"
                            Background="#3B82F6" Foreground="White" BorderThickness="0" FontWeight="Bold"
                            Click="AddFriendClicked">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <StackPanel x:Name="MyFriendCodeSection" Visibility="Collapsed">
                        <Separator Margin="0,24,0,24" Background="#252525"/>

                        <TextBlock Text="Your Friend Code" FontSize="18" FontWeight="Bold" 
                                   Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock Text="Share this code with others so they can add you." 
                                   FontSize="12" Foreground="#888888" 
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>

                        <Border Background="#121212" BorderBrush="#333333" 
                                BorderThickness="1" CornerRadius="8" Padding="14,12">
                            <TextBlock x:Name="MyFriendCodeText" Text="········" 
                                       FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="White" HorizontalAlignment="Center"/>
                        </Border>

                        <Button Content="Copy Code" Height="32" Margin="0,10,0,0"
                                Background="#2A2A2A" Foreground="White" BorderBrush="#333333"
                                Click="CopyCodeClicked">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Separator Margin="0,24,0,24" Background="#252525"/>
                        <TextBlock Text="Visibility" FontSize="15" FontWeight="Bold" 
                                   Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock x:Name="VisibilityDescription" Text="You are visible to friends." 
                                   FontSize="11" Foreground="#888888" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Button x:Name="VisibilityToggleButton" Height="34"
                                Background="#1E1E1E" Foreground="White" BorderBrush="#333333"
                                Click="VisibilityToggleClicked">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="VisibilityDot" Width="10" Height="10" Fill="#4CAF50" Margin="0,0,10,0"/>
                                <TextBlock x:Name="VisibilityButtonText" Text="Visible — Click to Hide" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- How it works -->
                    <Separator Margin="0,24,0,24" Background="#252525"/>
                    <TextBlock Text="How It Works" FontSize="16" FontWeight="Bold" 
                               Foreground="White" Margin="0,0,0,10"/>
                    <StackPanel Margin="4,0,0,0">
                        <TextBlock Text="1. Share your friend code with a friend" FontSize="11" Foreground="#777777" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <TextBlock Text="2. They enter your code and click Add Friend" FontSize="11" Foreground="#777777" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <TextBlock Text="3. Spark checks online matches for your friends" FontSize="11" Foreground="#777777" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <TextBlock Text="4. Click Join to hop into their game instantly" FontSize="11" Foreground="#777777" Margin="0,0,0,6" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Status footer -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,8">
                        <Ellipse x:Name="ApiStatusDot" Width="8" Height="8" Fill="#444444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ApiStatusText" Text="Not connected" FontSize="11" Foreground="#666666"/>
                    </StackPanel>
                    <Button Content="Refresh" Click="RefreshClicked" Height="26" FontSize="11"
                            Background="Transparent" BorderBrush="#252525" Foreground="#555555">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
