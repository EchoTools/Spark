<UserControl x:Class="Spark.WebBrowserTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:p="clr-namespace:Spark.Properties"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Background="{DynamicResource ControlDarkerBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tool Bar -->
        <Border Grid.Row="0" Background="{DynamicResource ControlDefaultBackground}" BorderBrush="{DynamicResource ControlDarkerBorderBrush}" BorderThickness="0,0,0,1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Content=" &lt; " Width="40" Height="30" Margin="0,0,5,0" Click="BackClicked" ToolTip="Back"/>
                <Button x:Name="ForwardButton" Grid.Column="1" Content=" &gt; " Width="40" Height="30" Margin="0,0,10,0" Click="ForwardClicked" ToolTip="Forward"/>

                <TextBox x:Name="AddressBar" Grid.Column="2" VerticalContentAlignment="Center" Padding="10,0" Height="30" 
                         Background="{DynamicResource ControlDarkerBackground}" Foreground="{DynamicResource ControlDefaultForeground}"
                         BorderBrush="{DynamicResource ControlDarkerBorderBrush}" KeyDown="AddressBarKeyDown"/>

                <Button x:Name="GoButton" Grid.Column="3" Content="Go" Width="50" Height="30" Margin="5,0" Click="GoClicked"/>
                <Button x:Name="SaveHomeButton" Grid.Column="4" Content="Set as Default" Padding="10,0" Height="30" Click="SaveHomeClicked" ToolTip="Save this page as your default browser tab"/>
            </Grid>
        </Border>

        <!-- Presets Bar -->
        <Border Grid.Row="1" Background="{DynamicResource ControlDarkerBackground}" Padding="10,5" BorderBrush="{DynamicResource ControlDarkerBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Presets:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" Foreground="{DynamicResource ControlDefaultForeground}"/>
                <Button Content="YouTube" Click="PresetClicked" Tag="https://www.youtube.com" Margin="0,0,5,0" Padding="8,2" Background="{DynamicResource ControlDefaultBackground}" Foreground="{DynamicResource ControlDefaultForeground}"/>
                <Button Content="Spotify" Click="PresetClicked" Tag="https://open.spotify.com" Margin="0,0,5,0" Padding="8,2" Background="{DynamicResource ControlDefaultBackground}" Foreground="{DynamicResource ControlDefaultForeground}"/>
                <Button Content="Apple Music" Click="PresetClicked" Tag="https://music.apple.com" Margin="0,0,5,0" Padding="8,2" Background="{DynamicResource ControlDefaultBackground}" Foreground="{DynamicResource ControlDefaultForeground}"/>
                <Button Content="Discord" Click="PresetClicked" Tag="https://discord.com/app" Margin="0,0,10,0" Padding="8,2" Background="{DynamicResource ControlDefaultBackground}" Foreground="{DynamicResource ControlDefaultForeground}"/>
                
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0" Background="{DynamicResource ControlDarkerBorderBrush}"/>
                
                <TextBlock VerticalAlignment="Center" FontSize="11" Opacity="0.7" Margin="10,0,0,0" Foreground="{DynamicResource ControlDefaultForeground}">
                    <Run Text="Presets are great for Media Controller or "/>
                    <Hyperlink Click="InfoLinkClicked" Tag="https://ranked.echocommunity.org/">Echo Ranked</Hyperlink>
                    <Run Text=" links!"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- WebView -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="2" />
    </Grid>
</UserControl>
